{
  "name": "vscode-svsch",
  "displayName": "SVSCH",
  "description": "Generate interactive visual block diagrams from SystemVerilog projects.",
  "version": "0.0.1",
  "publisher": "svsch",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:svsch.openDiagram",
    "onCommand:svsch.setProjectFolder",
    "onCommand:svsch.rebuildDiagram",
    "onCommand:svsch.resetLayout"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svsch.openDiagram",
        "title": "SVSCH: Open Diagram"
      },
      {
        "command": "svsch.setProjectFolder",
        "title": "SVSCH: Set Project Folder"
      },
      {
        "command": "svsch.rebuildDiagram",
        "title": "SVSCH: Rebuild Diagram"
      },
      {
        "command": "svsch.resetLayout",
        "title": "SVSCH: Reset Layout For Current Module"
      }
    ],
    "configuration": {
      "title": "SVSCH",
      "properties": {
        "svsch.projectFolder": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative folder containing SystemVerilog/Verilog sources."
        },
        "svsch.veriblePath": {
          "type": "string",
          "default": "verible-verilog-syntax",
          "description": "Path to the Verible verible-verilog-syntax executable."
        },
        "svsch.surelogPath": {
          "type": "string",
          "default": "surelog",
          "description": "Path to the Surelog executable."
        },
        "svsch.parser.backend": {
          "type": "string",
          "enum": [
            "uhdm",
            "verible",
            "fallback"
          ],
          "default": "uhdm",
          "description": "Parser backend used to extract the design graph."
        }
      }
    }
  },
  "scripts": {
    "clean": "rm -rf media dist node_modules/.vite",
    "compile": "npm run clean && vite build && tsc -p tsconfig.extension.json && npm run compile:backend && SURELOG_AUTO_INSTALL=1 npm run install-surelog",
    "compile:backend": "mkdir -p src/parser/backend_cpp/build && cd src/parser/backend_cpp/build && cmake .. -G Ninja && ninja svsch_backend && mkdir -p ../../../../dist/ && cp svsch_backend ../../../../dist/",
    "package": "SURELOG_AUTO_INSTALL=1 npm run compile && vsce package",
    "watch": "vite build --watch & tsc -watch -p tsconfig.extension.json",
    "lint": "tsc --noEmit -p tsconfig.extension.json && tsc --noEmit -p tsconfig.webview.json",
    "test": "vitest run",
    "test:backend": "export PATH=$PATH:$(pwd)/dist/surelog/bin && mkdir -p src/parser/backend_cpp/build && cd src/parser/backend_cpp/build && cmake .. -G Ninja && cmake --build . --target svsch_test && ./svsch_test",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "bundle-surelog": "node scripts/bundle-surelog.js --src \"$SURELOG_SRC\"",
    "install-surelog": "node scripts/install-surelog.js",
    "postinstall": "node scripts/install-surelog.js || true",
    "test:bdd": "start-server-and-test \"npm run visual:serve -- --force\" http://127.0.0.1:5176 \"cucumber-js\"",
    "docs:generate": "ts-node test/scripts/generate-docs.ts && ts-node test/scripts/html-to-pdf.ts",
    "visual:serve": "vite --host 127.0.0.1 --port 5176"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "1.59.0",
    "@types/node": "^25.6.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "start-server-and-test": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "semver": "^7.5.2",
    "uuid": "^14.0.0"
  }
}
